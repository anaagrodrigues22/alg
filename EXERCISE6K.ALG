Algoritmo "EXERCISE6K"

var
r, c, q: real

inicio
repita
escreval ("digite o valor da cotańŃo do dolar")
         leia (c)
atķ c > 0


repita
escreval ("digite a quantidade de dolares")
         leia (q)
atķ q > 0

r <- c * q

limpatela

escreval ("o usuario possui", r, " reais")


Fimalgoritmo