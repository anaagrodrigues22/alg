Algoritmo "D_DISTANCIAELITROS"

Var
l,t,v,d:real


Inicio
escreval("tempo:")
         leia(t)
escreval("velocidade:")
         leia(v)
         d<-t*v
escreval("sua distancia é de:" , d)
         l<-d/12
escreval("e a quantidade de litros usados foram usados:" , l , "L")

Fimalgoritmo