Algoritmo "E_PRESTAÇĂO"

Var
p,v,tx,t:real


Inicio
escreval ("Digite o valor")
         leia(v)
escreval ("Digite a taxa")
         leia(tx)
escreval ("Digite o tempo")
         leia (t)

         p <-v+(v*(tx/100) * t )

         limpatela
escreval ("prestaçăo =", p)
Fimalgoritmo