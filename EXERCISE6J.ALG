Algoritmo "EXERCISE6J"


Var
a, b, r: inteiro

Inicio
escreval ("digite um n·mero para saber o do quadrado da diferenńa")
         leia (a)

escreval ("digite outro n·mero")
         leia (b)
         
r <- ((a * a) - 2*a*b + (b * b))

limpatela

escreval ("o resultado do quadrado da diferenńa ķ de=", r)

Fimalgoritmo