Algoritmo "semnome"



Var
c, r, q, d: real

Inicio
repita
escreval ("digite a cotação do dólar para converter em reais")
         leia (c)
até c > 0

repita
escreval ("quanto reais você tem?")
         leia (r)
até r > 0
         
q <- r / c

limpatela
escreval ("voce tem", q, " dolares")




Fimalgoritmo