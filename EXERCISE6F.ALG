Algoritmo "EXERCISE6F"

Var
 a, b, troca: real
 
 inicio
 
escreval("digite um valor para a")
         leia(a)
         
escreval ("digite um valor para b")
         leia (b)
         
         troca <- a
         a <- b
         b <- troca

         limpatela
escreval ("A=" , a)
escreval ("B=" , b)

Fimalgoritmo